{
  "daemon": {
    "socket": "/run/gvisord/gvisord.sock",
    "pid_file": "/run/gvisord/gvisord.pid",
    "workdir": "/run/gvisord/sentries",
    "harness_path": "/var/gvisord/harness/gvisord-exec",
    "cache_dir": "/var/cache/gvisord"
  },
  "runsc": {
    "path": "/usr/local/bin/runsc",
    "extra_flags": []
  },
  "network": {
    "mode": "cni",
    "plugin_dir": "/opt/cni/bin",
    "config_dir": "/etc/cni/net.d",
    "bridge": "gvisord0",
    "subnet": "10.88.0.0/16"
  },
  "resource_classes": [
    {"name": "small",  "cpu_millis": 500,  "memory_mb": 512},
    {"name": "medium", "cpu_millis": 1000, "memory_mb": 1024},
    {"name": "large",  "cpu_millis": 2000, "memory_mb": 4096}
  ],
  "templates": {
    "python": {
      "rootfs": "/var/gvisord/images/python",
      "checkpoint": "/var/gvisord/checkpoints/python",
      "pools": [
        {"resource_class": "small",  "pool_size": 4, "max_pending": 8},
        {"resource_class": "medium", "pool_size": 2, "max_pending": 4},
        {"resource_class": "large",  "pool_size": 1, "max_pending": 2}
      ]
    },
    "node": {
      "rootfs": "/var/gvisord/images/node",
      "checkpoint": "/var/gvisord/checkpoints/node",
      "pools": [
        {"resource_class": "small",  "pool_size": 3, "max_pending": 6}
      ]
    }
  },
  "limits": {
    "max_restores_per_sentry": 100,
    "max_sentry_age": "10m",
    "max_rss_growth_kb": 204800,
    "max_open_fds": 512,
    "idle_timeout": "5m"
  }
}
